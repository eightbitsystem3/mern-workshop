pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('docker-hub-credentials')
        DOCKER_HUB_REPO = 'eightbitsystem3' // 
        BACKEND_IMAGE = "${DOCKER_HUB_REPO}/mern-backend"
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Deploy Backend Pod') {
            steps {
                echo 'Deploying backend pod to Kubernetes...'
                sh 'kubectl apply -f backend-pod.yaml'
            }
        }
    }
}