pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('docker-hub-credentials')
        DOCKER_HUB_REPO = 'eightbitsystem3'
        BACKEND_IMAGE = "${DOCKER_HUB_REPO}/mern-backend"
        MONGO_IMAGE = "${DOCKER_HUB_REPO}/mern-mongo"
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Build Backend Image') {
            steps {
                echo 'Building backend Docker image...'
                dir('backend') {
                    bat "docker build -t %BACKEND_IMAGE%:%BUILD_NUMBER% ."
                    bat "docker tag %BACKEND_IMAGE%:%BUILD_NUMBER% %BACKEND_IMAGE%:latest"
                }
            }
        }

        stage('Build MongoDB Image') {
            steps {
                echo 'Building MongoDB Docker image...'
                bat "docker build -f Dockerfile.mongo -t %MONGO_IMAGE%:%BUILD_NUMBER% ."
                bat "docker tag %MONGO_IMAGE%:%BUILD_NUMBER% %MONGO_IMAGE%:latest"
            }
        }

        stage('Login to Docker Hub') {
            steps {
                echo 'Logging into Docker Hub...'
                bat "echo %DOCKER_HUB_CREDENTIALS_PSW% | docker login -u %DOCKER_HUB_CREDENTIALS_USR% --password-stdin"
            }
        }

        stage('Push Images to Docker Hub') {
            steps {
                echo 'Pushing images to Docker Hub...'

                // Backend push
                bat "docker push %BACKEND_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %BACKEND_IMAGE%:latest"

                // Mongo push
                bat "docker push %MONGO_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %MONGO_IMAGE%:latest"
            }
        }

        stage('Cleanup') {
            steps {
                echo 'Cleaning up local Docker images...'
                bat "docker rmi %BACKEND_IMAGE%:%BUILD_NUMBER% %BACKEND_IMAGE%:latest"
                bat "docker rmi %MONGO_IMAGE%:%BUILD_NUMBER% %MONGO_IMAGE%:latest"
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed.'
            bat "docker logout"
        }
        success {
            echo 'Pipeline succeeded! Images pushed to Docker Hub.'
        }
        failure {
            echo 'Pipeline failed! Check the logs for details.'
        }
    }
}
