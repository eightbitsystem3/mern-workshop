pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('docker-hub-credentials')
        DOCKER_HUB_REPO = 'eightbitsystem3'
        FRONTEND_IMAGE = "${DOCKER_HUB_REPO}/mern-frontend"
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                checkout scm
            }
        }

        stage('Build Frontend Image') {
            steps {
                echo 'Building frontend Docker image...'
                dir('frontend') {
                    bat "docker build -t %FRONTEND_IMAGE%:%BUILD_NUMBER% ."
                    bat "docker tag %FRONTEND_IMAGE%:%BUILD_NUMBER% %FRONTEND_IMAGE%:latest"
                }
            }
        }

      stage('Test') {
            steps {
                echo 'Test run repository...'
                
            }
        }

        stage('Login to Docker Hub') {
            steps {
                echo 'Logging into Docker Hub...'
                bat "echo %DOCKER_HUB_CREDENTIALS_PSW% | docker login -u %DOCKER_HUB_CREDENTIALS_USR% --password-stdin"
            }
        }

        stage('Push Frontend Image to Docker Hub') {
            steps {
                echo 'Pushing frontend image to Docker Hub...'
                bat "docker push %FRONTEND_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %FRONTEND_IMAGE%:latest"
            }
        }

        stage('Cleanup') {
            steps {
                echo 'Cleaning up local Docker images...'
                bat "docker rmi %FRONTEND_IMAGE%:%BUILD_NUMBER% %FRONTEND_IMAGE%:latest"
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed.'
            bat "docker logout"
        }
        success {
            echo 'Pipeline succeeded! Frontend Image pushed to Docker Hub.'
        }
        failure {
            echo 'Pipeline failed! Check the logs for details.'
        }
    }
}
